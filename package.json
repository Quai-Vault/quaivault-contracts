{
  "name": "quaivault-contracts",
  "version": "1.0.0",
  "description": "QuaiVault smart contracts - Modular multisig wallet with Zodiac IAvatar compatibility for Quai Network",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test test/QuaiVault.test.ts test/QuaiVaultFactory.test.ts test/SocialRecoveryModule.test.ts test/TimelockDesign.test.ts test/TokenReceiver.test.ts test/ZodiacInterface.test.ts test/Integration.test.ts --network hardhat",
    "test:coverage": "hardhat coverage --network hardhat",
    "test:gas": "REPORT_GAS=true hardhat test test/QuaiVault.test.ts test/QuaiVaultFactory.test.ts test/SocialRecoveryModule.test.ts test/TimelockDesign.test.ts test/TokenReceiver.test.ts test/ZodiacInterface.test.ts test/Integration.test.ts --network hardhat",
    "test:e2e": "mocha --require ts-node/register --timeout 600000 --exit test/E2E.test.ts",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:cyprus1": "hardhat run scripts/deploy.ts --network cyprus1",
    "deploy:cyprus1:mock": "DEPLOY_MOCK_MODULE=true hardhat run scripts/deploy.ts --network cyprus1",
    "create-wallet": "hardhat run scripts/create-wallet.ts --network cyprus1",
    "update-env": "hardhat run scripts/update-env.ts",
    "verify": "hardhat verify",
    "clean": "hardhat clean",
    "lint": "solhint 'contracts/**/*.sol'",
    "format": "prettier --write 'contracts/**/*.sol'"
  },
  "keywords": [
    "quai",
    "quaivault",
    "multisig",
    "smart-contracts",
    "zodiac",
    "dao"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.3",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.6",
    "chai": "^4.3.10",
    "hardhat": "^2.19.5",
    "hardhat-gas-reporter": "^1.0.9",
    "prettier": "^3.1.1",
    "prettier-plugin-solidity": "^1.3.1",
    "solhint": "^4.1.1",
    "solidity-coverage": "^0.8.5",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.0.0",
    "@quai/hardhat-deploy-metadata": "^1.0.8",
    "@quai/quais-upgrades": "^3.8.14",
    "dotenv": "^16.4.5",
    "quais": "^1.0.0-alpha.53"
  }
}
