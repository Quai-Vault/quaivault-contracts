# E2E Test Configuration
# Copy to .env.e2e and fill in values
#
# Prerequisites before running E2E tests:
# 1. Contracts deployed: npm run deploy:cyprus1:mock
# 2. Env synced: npm run update-env
# 3. Test wallets funded: Each private key needs testnet QUAI for gas

# =============================================================================
# Quai Network Configuration
# =============================================================================

# Quai Network RPC (Orchard Testnet)
# Use base URL without shard path - the SDK uses usePathing: true
QUAI_RPC_URL=https://rpc.orchard.quai.network
QUAI_WS_URL=wss://rpc.orchard.quai.network
QUAI_CHAIN_ID=15000

# =============================================================================
# Test Wallet Private Keys
# =============================================================================
#
# SECURITY WARNING: These keys should ONLY be used for testing!
# Never use keys with real mainnet funds.
#
# Minimum 3 owners for multisig threshold testing
# Minimum 2 guardians for social recovery testing

OWNER_PRIVATE_KEY_1=0x...
OWNER_PRIVATE_KEY_2=0x...
OWNER_PRIVATE_KEY_3=0x...

GUARDIAN_PRIVATE_KEY_1=0x...
GUARDIAN_PRIVATE_KEY_2=0x...

# =============================================================================
# Deployed Contract Addresses
# =============================================================================
#
# Run 'npm run update-env' after deployment to auto-populate these values.

# Required Contracts
QUAIVAULT_FACTORY=0x...
QUAIVAULT_IMPLEMENTATION=0x...

# Module Contracts
SOCIAL_RECOVERY_MODULE=0x...
MULTISEND_CALL_ONLY=0x...

# Test Contracts (deployed with npm run deploy:cyprus1:mock)
MOCK_MODULE=0x...
MOCK_ERC721=0x...
MOCK_ERC1155=0x...
